---
import Layout from '../../../layouts/Layout.astro';
import HeaderLogoOnly from '../../../components/HeaderLogoOnly.astro';
import Footer from '../../../components/Footer.astro';
---

<Layout title="Connected accounts">
  <div class="d-flex flex-column min-vh-100">
    <HeaderLogoOnly />

    <main class="flex-grow-1 px-3 py-4">
      <div class="w-100 mx-auto" style="max-width: 480px;">
        <a href="#" class="row g-2 align-items-center mb-3 text-link" aria-label="Go back to account settings">
          <div class="col-auto">
            <i class="fas fa-arrow-left" aria-hidden="true"></i>
          </div>
          <div class="col">
            <p class="fw-semibold mb-0 text-link">Account settings</p>
          </div>
        </a>

        <div class="panel-default w-100 p-4">
          <section class="mb-4">
            <h3 class="mb-3 text-main">Connected accounts</h3>
            <p class="mb-0">
              Connect or disconnect your SSO accounts for faster sign-in.
              <br />
              Use any connected account to log in.
            </p>
          </section>

          <section class="mb-4 pb-2">
            <h5 class="mb-3 text-main">Your connected SSO accounts</h5>
            <div class="d-grid gap-3">
              <article class="border rounded-4 bg-white p-3" aria-label="Google connected account">
                <div class="row g-3 align-items-center">
                  <div class="col-sm">
                    <div class="row g-3 align-items-center">
                      <div class="col-auto">
                        <i class="fab fa-google text-primary fs-4" aria-hidden="true"></i>
                      </div>
                      <div class="col">
                        <h5 class="mb-1 text-main">Google</h5>
                        <span class="small text-success-plus-1">
                          <i class="fa-regular fa-circle-check me-1" aria-hidden="true"></i>
                          Connected
                        </span>
                      </div>
                    </div>
                  </div>
                  <div class="col-12 col-sm-auto">
                    <button type="button" class="btn btn-outline-default w-100">
                      Disconnect
                    </button>
                  </div>
                </div>
              </article>
            </div>
          </section>

          <section>
            <h5 class="mb-3 text-main">Available SSO accounts</h5>
            <div class="d-grid gap-3">
              <article class="border rounded-4 bg-white p-3" aria-label="Apple available account">
                <div class="row g-3 align-items-center">
                  <div class="col-sm">
                    <div class="row g-3 align-items-center">
                      <div class="col-auto">
                        <i class="fab fa-apple text-main fs-4" aria-hidden="true"></i>
                      </div>
                      <div class="col">
                        <h5 class="mb-0 text-main">Apple</h5>
                      </div>
                    </div>
                  </div>
                  <div class="col-12 col-sm-auto">
                    <button type="button" class="btn btn-success w-100">
                      Connect
                    </button>
                  </div>
                </div>
              </article>

              <article class="border rounded-4 bg-white p-3" aria-label="netID available account">
                <div class="row g-3 align-items-center">
                  <div class="col-sm">
                    <div class="row g-3 align-items-center">
                      <div class="col-auto">
                        <i class="fas fa-id-card text-gray-plus-1 fs-4" aria-hidden="true"></i>
                      </div>
                      <div class="col">
                        <h5 class="mb-0 text-main">netID</h5>
                      </div>
                    </div>
                  </div>
                  <div class="col-12 col-sm-auto">
                    <button type="button" class="btn btn-success w-100">
                      Connect
                    </button>
                  </div>
                </div>
              </article>
            </div>
          </section>
        </div>
      </div>
    </main>

    <Footer />
  </div>
</Layout>
